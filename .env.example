# Copy this file to .env and adjust values as needed.
# docker-compose.yml reads .env automatically.

# Shared
REDIS_URL=redis://redis:6379
RESULT_TTL=300

# API
REQUEST_TIMEOUT=30
POLL_INTERVAL=0.1
API_HOST=0.0.0.0
API_PORT=8000

# Worker
WORKER_ID=worker-1
SUPPORTED_MODELS=text-small,text-large,image-small
POLL_TIMEOUT=1
WORKER_METRICS_PORT=9090
